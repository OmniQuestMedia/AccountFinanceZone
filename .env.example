# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/accounts_finance_zone

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Data Residency
DATA_RESIDENCY_REGION=ca-central-1

# Compliance Integration
COMPLIANCE_ZONE_URL=http://omni-compliance-zone:4000

# KMS Configuration (AWS KMS for encryption-at-rest)
# Separate KMS key for financial data encryption
AWS_REGION=ca-central-1
AWS_KMS_KEY_ID=arn:aws:kms:ca-central-1:ACCOUNT_ID:key/YOUR_KEY_ID
AWS_KMS_KEY_ALIAS=alias/accountfinancezone-encryption-key

# Optional: AWS Credentials (use IAM roles in production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Database Encryption (PostgreSQL pgcrypto extension)
# Used for column-level encryption of sensitive tokenized data
DB_ENCRYPTION_ENABLED=true

# Webhook Integration
# Destination for forwarded finance events (v1.1 webhook contract). When unset,
# events are logged locally and not forwarded — safe for local/unit testing.
ECOMMSZONE_WEBHOOK_URL=http://ecomms-zone:5000/webhooks/finance
# Optional shared secret; enables HMAC-SHA256 (sha256=) signing of deliveries.
ECOMMSZONE_WEBHOOK_SECRET=your-webhook-secret-here

# Payout Rails
# Required only when CRYPTO_NOWPAYMENTS settlements are enabled.
NOWPAYMENTS_API_KEY=your-nowpayments-api-key

# Encryption
# Arbitrary string; SHA-256 hashed at runtime to derive the AES-256-GCM key used
# for sensitive payout-preference fields (bank/wire/mailing details).
ENCRYPTION_MASTER_KEY=change-me-in-production

# Application Environment
NODE_ENV=development
PORT=3000
